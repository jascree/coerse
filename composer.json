{
    "name": "jascree/try-cast",
    "description": "Safe type coercion for PHP – returns null on failure, no exceptions, no dependencies.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "coerce",
        "normalize"
    ],
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "Jascree\\TryCast\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jascree\\TryCast\\Tests\\": "tests"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "10.5.63"
    },
    "scripts": {
        "test": "phpunit --colors=always"
    }
}
